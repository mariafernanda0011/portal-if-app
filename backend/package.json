{
  "name": "portal-if-backend",
  "version": "1.0.0",
  "description": "API do Portal IFNMG desenvolvida com Node.js, Express e TypeScript",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "reinstall": "rimraf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "node",
    "express",
    "typescript",
    "mongodb",
    "mongoose",
    "jwt",
    "backend",
    "ifnmg"
  ],
  "author": "Renato",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "rimraf": "^6.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
